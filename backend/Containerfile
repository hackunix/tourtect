FROM docker.io/library/golang:1.26.5-alpine AS build

WORKDIR /src
RUN apk add --no-cache ca-certificates git

COPY go.mod go.sum ./
RUN go mod download

COPY . .
ARG GOOSE_VERSION=v3.27.2
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/tourtect-api ./cmd/api \
    && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/tourtect-realtime ./cmd/realtime \
    && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/tourtect-worker ./cmd/worker \
    && GOBIN=/out go install -tags="no_clickhouse no_libsql no_mssql no_mysql no_sqlite3 no_vertica no_ydb" github.com/pressly/goose/v3/cmd/goose@${GOOSE_VERSION}

FROM docker.io/library/alpine:3.22

RUN apk add --no-cache ca-certificates postgresql-client tzdata wget \
    && addgroup -S tourtect \
    && adduser -S -G tourtect -h /app tourtect

WORKDIR /app
COPY --from=build /out/tourtect-api /out/tourtect-realtime /out/tourtect-worker /out/goose /usr/local/bin/
COPY --from=build /src/db/migrations ./migrations
COPY --from=build /src/db/seed ./seed
COPY --chmod=755 scripts/container-migrate.sh /usr/local/bin/tourtect-migrate
COPY --chmod=755 scripts/container-seed.sh /usr/local/bin/tourtect-seed
COPY --chmod=755 scripts/container-start-api.sh /usr/local/bin/tourtect-start-api

USER tourtect
EXPOSE 8080 8081 8082
CMD ["tourtect-api"]
