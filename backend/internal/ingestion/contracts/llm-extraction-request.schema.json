{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tourtect.example/schemas/llm-extraction-request.schema.json",
  "title": "LLM Extraction Request",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "task",
    "allowed_record_types",
    "source_document",
    "context",
    "constraints"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string" },
    "request_id": { "type": "string" },
    "task": { "type": "string" },
    "allowed_record_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_document": {
      "$ref": "raw-source-document.schema.json"
    },
    "context": {
      "type": "object",
      "required": ["target_country", "current_time"],
      "additionalProperties": false,
      "properties": {
        "target_country": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "target_regions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "known_places": {
          "type": "array",
          "items": { "type": "string" }
        },
        "known_categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "current_time": { "type": "string", "format": "date-time" }
      }
    },
    "constraints": {
      "type": "object",
      "required": ["must_use_source_only", "must_not_guess", "must_return_json_only"],
      "additionalProperties": false,
      "properties": {
        "must_use_source_only": { "type": "boolean" },
        "must_not_guess": { "type": "boolean" },
        "must_return_json_only": { "type": "boolean" },
        "maximum_records": { "type": "integer", "minimum": 1 },
        "minimum_confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    }
  }
}
