# Copy this file to .env before starting the local stack.
# Never commit a real FPT AI Factory API key.

COMPOSE_PROJECT_NAME=tourtect
TZ=Asia/Ho_Chi_Minh

# FPT AI Factory / AI Inference (OpenAI-compatible API)
# Demo override. Supported architecture modes: adaptive, server_only, local_only.
AI_EXECUTION_MODE=server_only
AI_PROVIDER=fpt_ai_factory
FPT_AI_BASE_URL=https://mkp-api.fptcloud.com
FPT_AI_API_KEY=replace_with_your_fpt_ai_factory_api_key
FPT_AI_TEXT_MODEL=Qwen/Qwen3-32B
FPT_AI_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# OCR uses the server VLM by default; override if your key has a dedicated OCR model.
FPT_AI_OCR_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# Replace these with STT/TTS model IDs enabled for your Marketplace API key.
FPT_AI_STT_MODEL=replace_with_enabled_stt_model_id
FPT_AI_TTS_MODEL=replace_with_enabled_tts_model_id
FPT_AI_TIMEOUT_SECONDS=30
FPT_AI_MAX_RETRIES=2

# Android demo client. iOS is out of scope for this demo.
ANDROID_APPLICATION_ID=vn.tourtect.app
# Emulator/debug only. Production Android builds must use HTTPS/WSS endpoints.
ANDROID_API_BASE_URL=http://192.168.1.204:8080
ANDROID_REALTIME_URL=ws://192.168.1.204:8080/v1/realtime

# External content ingestion (backend/worker only)
CRAWLER_USER_AGENT=TourtectBot/0.1 (+https://tourtect.example/crawler; data@tourtect.example)
CRAWLER_DEFAULT_HOST_RPS=0.2
CRAWLER_DEFAULT_HOST_CONCURRENCY=1
CRAWLER_ROBOTS_CACHE_SECONDS=86400
CRAWLER_MAX_RESPONSE_BYTES=5242880
YOUTUBE_DATA_API_KEY=

# OpenStreetMap bootstrap/replication. Review ODbL attribution before use.
OSM_PBF_URL=https://download.geofabrik.de/asia/vietnam-latest.osm.pbf
OSM_REPLICATION_URL=https://planet.openstreetmap.org/replication/hour

# PostgreSQL / PostGIS
POSTGRES_DB=tourtect
POSTGRES_USER=tourtect
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379

# MinIO (S3-compatible local object storage)
MINIO_ROOT_USER=tourtect
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# OpenSearch (single-node demo only)
OPENSEARCH_PORT=9200
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
